name: Build Linux apps

on:
  push:
    
jobs:
  build-linux:
    runs-on: ubuntu-22.04
    steps:
    - uses: actions/checkout@v4
    - name: Get .env
      env:
        REPO_TOKEN: ${{ secrets.REPO_TOKEN }}
      run: |
        curl -H "Authorization: token $REPO_TOKEN" -H "Accept: application/vnd.github.v3.raw" -o .env -L https://api.github.com/repos/rtr-nettest/open-rmbt-desktop-private/contents/.env.windows-ci
    - name: Use Node.js ${{ matrix.node-version }}
      uses: actions/setup-node@v3
      with:
        node-version: 18.x
    - name: Build
      run: |
        pwd
        ls -l
        cd binaries
        # get release of Java engine
        wget -q https://github.com/rtr-nettest/open-rmbt/releases/download/v0.9/RTR-NetztestCLI-linux-x64.zip
        # unpack
        unzip -q RTR-NetztestCLI-linux-x64.zip
        mv RTR-Netztest/* RTR-NetztestCLI-linux-x64
        ls -l
        # return to repository root directory
        cd ..
        # check directory again
        pwd
        sudo apt-get install -y rpm
        npm install
        cd src/ui
        npm install
        # again return to repository root directory
        cd ../..
        npm run make:deb
        npm run make:rpm
    - uses: actions/upload-artifact@v4
      with:
        name: application-rpm
        path: out/make/rpm/x64/*.rpm
    - uses: actions/upload-artifact@v4
      with:
        name: application-deb
        path: out/make/deb/x64/*.deb
        
    - name: Intermediate file check
      run: |
        cd  out/make/rpm/x64/
        ls -l *
    - name: Release
      uses: softprops/action-gh-release@v2
      if: github.ref_type == 'tag'
      with:
        files: |
          out/make/deb/x64/open-rmbt-desktop_2.0.0_amd64.deb
          out/make/rpm/x64/open-rmbt-desktop-2.0.0-1_x86_64.rpm
